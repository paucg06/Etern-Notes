<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EternNotes.MainWindow"
        Title="Etern-Notes // Workspace"
        Width="1150" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid RowDefinitions="Auto,*">
        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#1A1A1A" Height="42" Padding="15,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M6,15H5V13H3V12H5V10H6V12H8V13H6V15M15.5,12A1.5,1.5 0 0,1 14,10.5A1.5,1.5 0 0,1 15.5,9A1.5,1.5 0 0,1 17,10.5A1.5,1.5 0 0,1 15.5,12M18.5,15A1.5,1.5 0 0,1 17,13.5A1.5,1.5 0 0,1 18.5,12A1.5,1.5 0 0,1 20,13.5A1.5,1.5 0 0,1 18.5,15Z"
                          Fill="#007ACC" Width="18" Height="18" Stretch="Uniform" />
                    <TextBlock Text="Etern-Notes // Cross-Platform Workspace" 
                               FontWeight="Bold" FontSize="13" Foreground="#C8C8C8" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" ColumnDefinitions="240,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#303030" BorderThickness="0,0,1,0" Padding="15">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="PROYECTOS" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,10" />
                    
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Name="ProjectListPanel" Spacing="6" />
                    </ScrollViewer>

                    <Button Grid.Row="2" Name="BtnNewProject" Content="+ Nuevo Proyecto" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Background="#007ACC" Foreground="White" Padding="10,8" CornerRadius="4" Click="BtnNewProject_Click" />
                </Grid>
            </Border>

            <!-- Main Kanban Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="20">
                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                    <StackPanel Grid.Column="0">
                        <TextBlock Name="TxtProjectTitle" Text="Mi Proyecto" FontSize="22" FontWeight="Bold" Foreground="White" />
                        <TextBlock Name="TxtProjectDesc" Text="Gestión de tareas y backlog" FontSize="13" Foreground="#888888" Margin="0,4,0,0" />
                    </StackPanel>

                    <Button Grid.Column="1" Name="BtnNewTask" Content="+ Nueva Tarea" 
                            Background="#007ACC" Foreground="White" Padding="12,8" CornerRadius="4" Click="BtnNewTask_Click" />
                </Grid>

                <!-- Kanban Columns -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <Grid Name="KanbanGrid" ColumnDefinitions="*,*,*" System.Threading.Tasks.Task.Delay="0">
                        <!-- Columns generated dynamically -->
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
